{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ISMS·LA 練習題庫 exam.json",
  "type": "object",
  "required": ["items"],
  "additionalProperties": true,
  "properties": {
    "meta": { "type": "object" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "topic", "type", "stem", "options", "answer", "explain"],
        "properties": {
          "id": { "type": "string", "pattern": "^q[0-9]{3,}$" },
          "topic": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["single", "multi", "tf"] },
          "stem": { "type": "string", "minLength": 1 },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["k", "t"],
              "properties": {
                "k": { "type": "string", "minLength": 1 },
                "t": { "type": "string", "minLength": 1 }
              }
            }
          },
          "answer": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "explain": { "type": "string", "minLength": 1 },
          "refs": { "type": "array", "items": { "type": "string" } },
          "difficulty": { "type": "integer", "minimum": 1, "maximum": 3 },
          "source": { "type": "string" }
        }
      }
    }
  }
}
