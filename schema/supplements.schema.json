{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Supplements (老師補充 / 相關標準) 活檔",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "_about": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nodeId", "title", "note"],
        "additionalProperties": false,
        "properties": {
          "nodeId": { "type": "string", "minLength": 1 },
          "ref": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
